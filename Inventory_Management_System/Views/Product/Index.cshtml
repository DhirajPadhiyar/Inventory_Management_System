@model List<Inventory_Management_System.Models.Product>

@{
    ViewData["Title"] = "Products";
}

<h2>Product List</h2>

@if (TempData["success"] != null)
{
    <div class="alert alert-success text-center">
        @TempData["success"]
    </div>
}

@if (TempData["error"] != null)
{
    <div class="alert alert-danger text-center">
        @TempData["error"]
    </div>
}

<a asp-controller="Product" asp-action="Create" class="btn btn-success mb-3">
    Add Product
</a>

<table class="table table-bordered table-hover table-sm">
    <thead>
        <tr>
            <th style="text-align:center">Name</th>
            <th style="text-align:center">Price</th>
            <th style="text-align:center">Quantity</th>
            <th style="text-align:center">Category</th>
            <th style="width:80px; text-align:center;">Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td style="text-align:center">@item.Name</td>
                <td style="text-align:center">@item.Price.ToString("0.00")</td>
                <td style="text-align:center">@item.Quantity</td>
                <td style="text-align:center">@item.Category?.Name</td>

                <td class="text-center">

                    <div class="dropdown">
                        <button class="btn btn-sm btn-outline-primary" data-bs-toggle="dropdown" title="Actions">
                            <i class="bi bi-pencil"></i>
                        </button>

                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <a class="dropdown-item"
                                       asp-action="StockHistory"
                                       asp-route-productId="@item.Id">
                                    📊 History
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" asp-action="Edit" asp-route-id="@item.Id">
                                    ✏️ Edit
                                </a>
                            </li>

                            <li>
                                <button type="button"
                                        class="dropdown-item text-danger"
                                        data-bs-toggle="modal"
                                        data-bs-target="#deleteModal"
                                        onclick="setDeleteData(@item.Id, '@item.Name.Replace("'", "\\'")')">
                                    🗑️ Delete
                                </button>
                            </li>
                        </ul>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- DELETE MODAL -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title text-danger">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                Are you sure you want to delete
                <strong id="productName" class="text-danger"></strong>?
            </div>

            <div class="modal-footer">
                <form id="deleteForm" method="post">
                    <button type="submit" class="btn btn-danger">Yes, Delete</button>
                </form>

                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    Cancel
                </button>
            </div>

        </div>
    </div>
</div>

<script>
    function setDeleteData(id, name) {
        document.getElementById("deleteForm").action = '/Product/Delete/' + id;
        document.getElementById("productName").innerText = name;
    }
</script>